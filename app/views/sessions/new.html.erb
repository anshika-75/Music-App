<div class="welcome-container">
  <h1 class="welcome-logo">🎵 Music App</h1>
  <p class="welcome-subtitle">Your personal space for uploading, caching, and discovering premium audio tracks.</p>

  <div class="container-card" style="text-align: left; padding: 2rem; margin-top: 1rem;">
    <h2 style="text-align: center; margin-bottom: 1.5rem;">Sign In to Your Account</h2>

    <%= form_with url: login_path, local: true, data: { turbo: false } do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email Address" %>
        <%= f.email_field :email, placeholder: "you@example.com", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, placeholder: "••••••••", required: true %>
      </div>

      <div style="margin-top: 1.5rem;">
        <%= f.submit "Log In", class: "btn btn-primary", style: "width: 100%;" %>
      </div>
    <% end %>
  </div>

  <div style="margin-top: 1.5rem;">
    <p>New to Music App? <a href="<%= new_user_path %>" style="font-weight: 600;">Create an account now</a></p>
  </div>
</div>
