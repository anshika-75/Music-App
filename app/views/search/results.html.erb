<div class="grid-2">
  <div>
    <div class="container-card">
      <h2>Listener Profile</h2>
      <div style="margin-top: 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; text-align: center;">
        
        <div class="profile-avatar-container" style="width: 120px; height: 120px;">
          <% if @profile&.profile_photo.present? %>
            <img src="<%= @profile.profile_photo %>" alt="Profile Photo">
          <% else %>
            <div class="profile-avatar-fallback" style="font-size: 3rem;">👤</div>
          <% end %>
        </div>

        <div class="profile-details" style="margin-top: 0.5rem;">
          <p style="font-size: 1.25rem; font-weight: 600; color: var(--text-primary);">
            <%= @profile&.name.presence || "No Name Provided" %>
          </p>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.25rem;"><%= current_user.email %></p>
        </div>

        <div style="margin-top: 1rem; width: 100%;">
          <a href="<%= edit_listener_profile_path(@profile) %>" class="btn btn-secondary" style="width: 100%;">Edit Profile Details</a>
        </div>
      </div>
    </div>
  </div>

  <div>
    <div class="container-card">
      <h2>Search Songs</h2>
      <p style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 2rem;">
        Search for your favorite tracks by song title or artist name.
      </p>

      <%= form_with url: search_results_path, method: :get, local: true, class: "search-form-container", data: { turbo: false } do |f| %>
        <div class="search-input-group">
          <%= f.text_field :query, placeholder: "Enter song title or artist name...", value: params[:query], required: true %>
          <%= f.submit "Search", class: "btn btn-primary" %>
        </div>
      <% end %>

      <div style="margin-top: 2.5rem;">
        <h3 style="margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between;">
          <span>Search Results for "<span style="color: var(--primary);"><%= @query %></span>"</span>
          <span class="role-badge" style="background-color: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2); color: var(--secondary);"><%= pluralize(@songs.size, "match") %></span>
        </h3>

        <% if @songs.any? %>
          <div class="song-list-grid">
            <% @songs.each do |song| %>
              <div class="song-card" style="flex-direction: column; align-items: stretch; gap: 1rem;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                  <div class="song-info">
                    <span class="song-title"><%= song.title %></span>
                    <span style="font-size: 0.85rem; color: var(--text-secondary);">
                      🎙️ Artist: <strong><%= song.artist_name %></strong>
                    </span>
                    <% if song.genre.present? %>
                      <span style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">
                        🏷️ Genre: <%= song.genre %>
                      </span>
                    <% end %>
                  </div>
                  <div>
                    <a href="<%= song_path(song) %>" class="btn btn-secondary btn-sm" style="height: auto;">View Details</a>
                  </div>
                </div>

                <div class="audio-player-wrapper" style="max-width: 100%; margin-top: 0.25rem;">
                  <audio src="<%= song.mp3_file_path %>" controls></audio>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state" style="border-color: var(--danger); background-color: rgba(239, 68, 68, 0.02);">
            <p style="font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--danger);">🚫 No songs found</p>
            <p style="font-size: 0.9rem; margin-bottom: 0;">Try searching for a different song name or artist.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
